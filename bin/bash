git clone https://github.com/erlang-ls/erlang_ls
cd erlang_ls
rebar3 escriptize
# Add _build/default/bin/erlang_ls to your PATH
# Create a new Erlang application named "myapp"
rebar3 new app myapp
cd myapp

# Compile the code
rebar3 compile

# Open a shell with your app and dependencies loaded
rebar3 shell
